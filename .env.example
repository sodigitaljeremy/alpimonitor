# AlpiMonitor — environment variables (dev docker-compose)
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# --- PostgreSQL (service: postgres) ---
POSTGRES_USER=alpimonitor
POSTGRES_PASSWORD=alpimonitor_dev
POSTGRES_DB=alpimonitor

# DATABASE_URL uses the compose service name "postgres" as host,
# so inter-container DNS resolves correctly from the api container.
# For psql from the host machine, use localhost:5432 instead.
DATABASE_URL=postgresql://alpimonitor:alpimonitor_dev@postgres:5432/alpimonitor

# --- API (service: api) ---
# 0.0.0.0 is required inside the container so the port is reachable from the host.
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Comma-separated list of allowed origins for CORS. Leave the dev value for now.
CORS_ORIGINS=http://localhost:5173
