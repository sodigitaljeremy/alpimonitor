# AlpiMonitor — production environment variables template.
#
# For the Coolify deployment, set these in the project's "Environment Variables"
# panel (UI), not by committing a real .env.production to the repo.
#
# Local prod smoke test:
#   cp .env.production.example .env.production
#   # fill in POSTGRES_PASSWORD at minimum, keep DATABASE_URL host = "postgres"
#   docker compose -f docker-compose.prod.yml --env-file .env.production up --build

# --- PostgreSQL ---
POSTGRES_USER=alpimonitor
POSTGRES_PASSWORD=change_me_in_coolify
POSTGRES_DB=alpimonitor

# Host "postgres" resolves via the compose service network; do not change unless
# you rename the service. In Coolify, this value stays identical.
DATABASE_URL=postgresql://alpimonitor:change_me_in_coolify@postgres:5432/alpimonitor

# --- API (Fastify) ---
# Comma-separated list. In production, match exactly the public web origin.
CORS_ORIGINS=https://alpimonitor.fr
LOG_LEVEL=info

# --- LINDAS ingestion cron ---
# Set to "false" for one-off runs (migrations-only containers). Default: true.
INGESTION_ENABLED=true
# node-cron expression. Default: every 10 minutes.
INGESTION_SCHEDULE=*/10 * * * *

# --- Boot-time seed ---
# When "true", the entrypoint runs `prisma db seed` after applying migrations.
# The seed is idempotent (upsert on ofevCode, etc.), so running it on every
# boot is safe for demo/POC. Set to "false" for environments where real
# operational data must not be overwritten by seed fixtures.
SEED_ON_BOOT=true

# --- Web (Vite bundle) ---
# Baked into the JS bundle at build time. A change requires a rebuild of the
# web image, not just a container restart.
VITE_API_BASE_URL=https://api.alpimonitor.fr/api/v1
