# Base URL (without trailing slash) for the AlpiMonitor REST API.
# Vite inlines VITE_* vars at build time, so a real value must be set
# before `vite build` (dev server reads it on startup).
#
# Local dev (API on same host):  http://localhost:3000/api/v1
# Production:                    https://api.alpimonitor.fr/api/v1
VITE_API_BASE_URL=http://localhost:3000/api/v1
